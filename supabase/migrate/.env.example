# Copy this to `.env` in the same folder and fill in real values.
# NEVER commit .env — it contains a secret key that bypasses RLS.

SUPABASE_URL=https://wllsrdfflaudwhfpxzfe.supabase.co

# service_role key (secret!) — grab from:
#   https://supabase.com/dashboard/project/wllsrdfflaudwhfpxzfe/settings/api
